# --- Auth service configuration (12-factor; all via environment) ---

# Service
SERVICE_NAME=auth-service
ENVIRONMENT=development
HTTP_PORT=8081
LOG_LEVEL=info

# PostgreSQL (required)
POSTGRES_DSN=postgres://auth:auth@localhost:5432/auth?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2

# Redis (optional — used only for rate limiting; service runs without it)
REDIS_ADDR=localhost:6379
REDIS_DB=0

# Kafka (transactional-outbox relay target)
KAFKA_BROKERS=localhost:9092

# JWT signing (RS256). Provide EITHER the PEM inline or a file path.
# Generate with: ./scripts/gen-jwt-keys.sh ./secrets
JWT_PRIVATE_KEY_FILE=./secrets/jwt_private.pem
JWT_KEY_ID=auth-key-1
JWT_ISSUER=embedded-market-auth
JWT_AUDIENCE=embedded-market
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# OAuth providers (optional — leave blank to disable a provider)
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8081/api/v1/auth/oauth/github/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8081/api/v1/auth/oauth/google/callback
OAUTH_GITLAB_CLIENT_ID=
OAUTH_GITLAB_CLIENT_SECRET=
OAUTH_GITLAB_REDIRECT_URL=http://localhost:8081/api/v1/auth/oauth/gitlab/callback

# Cookies
COOKIE_REFRESH_NAME=em_refresh_token
COOKIE_OAUTH_STATE_NAME=em_oauth_state
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Rate limiting (per identity, fixed window)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=1m

# Transactional outbox relay
OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=100
