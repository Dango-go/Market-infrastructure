# --- User service configuration ---
SERVICE_NAME=user-service
ENVIRONMENT=development
HTTP_PORT=8082
LOG_LEVEL=info

POSTGRES_DSN=postgres://user:user@localhost:5432/user?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2

KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=user-service

JWT_PUBLIC_KEY_FILE=./secrets/jwt_public.pem
JWT_ISSUER=embedded-market-auth
JWT_AUDIENCE=embedded-market

OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=100
