# Shared Go service environment template for Embedded Market.
# Copy this file per service and keep only the blocks that service actually needs.
# Suggested usage:
#   cp backend/.env.service.template backend/services/<service>/.env
# Then remove unused sections and fill real values.

# -----------------------------------------------------------------------------
# Common service settings
# -----------------------------------------------------------------------------
SERVICE_NAME=replace-me-service
ENVIRONMENT=development
HTTP_PORT=8080
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# PostgreSQL
# Required for most domain services: auth, user, catalog, inventory, pricing,
# cart, order, shipping, payment, notification, search, review,
# recommendation, analytics.
# Gateway usually does not need this block.
# -----------------------------------------------------------------------------
POSTGRES_DSN=postgres://user:password@postgres:5432/service_db?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_CONNECT_TIMEOUT=5s

# -----------------------------------------------------------------------------
# JWT verification
# Required for api-gateway and all services that validate access tokens.
# Use EITHER *_FILE or *_PEM.
# -----------------------------------------------------------------------------
JWT_PUBLIC_KEY_FILE=./secrets/jwt_public.pem
# JWT_PUBLIC_KEY_PEM=
JWT_ISSUER=embedded-market-auth
JWT_AUDIENCE=embedded-market

# -----------------------------------------------------------------------------
# JWT signing
# Required only for auth-service.
# Use EITHER *_FILE or *_PEM.
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY_FILE=./secrets/jwt_private.pem
# JWT_PRIVATE_KEY_PEM=
JWT_KEY_ID=auth-key-1
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# -----------------------------------------------------------------------------
# Redis
# Optional right now. Auth service uses it for rate limiting.
# -----------------------------------------------------------------------------
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Kafka / event bus
# Needed for services that publish or relay outbox events.
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka:9092
OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Auth cookies
# Required only for auth-service.
# In production usually set COOKIE_SECURE=true.
# -----------------------------------------------------------------------------
COOKIE_REFRESH_NAME=em_refresh_token
COOKIE_OAUTH_STATE_NAME=em_oauth_state
COOKIE_DOMAIN=
COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Auth rate limiting
# Required only for auth-service.
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=1m

# -----------------------------------------------------------------------------
# OAuth providers
# Optional, auth-service only.
# Leave blank to disable.
# -----------------------------------------------------------------------------
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8081/api/v1/auth/oauth/github/callback

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8081/api/v1/auth/oauth/google/callback

OAUTH_GITLAB_CLIENT_ID=
OAUTH_GITLAB_CLIENT_SECRET=
OAUTH_GITLAB_REDIRECT_URL=http://localhost:8081/api/v1/auth/oauth/gitlab/callback

# -----------------------------------------------------------------------------
# API gateway upstreams
# Required only for api-gateway.
# In Kubernetes replace with service DNS names.
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://auth-service:8081
USER_SERVICE_URL=http://user-service:8082
CATALOG_SERVICE_URL=http://catalog-service:8083
INVENTORY_SERVICE_URL=http://inventory-service:8084
PRICING_SERVICE_URL=http://pricing-service:8085
CART_SERVICE_URL=http://cart-service:8086
ORDER_SERVICE_URL=http://order-service:8087
SHIPPING_SERVICE_URL=http://shipping-service:8088
PAYMENT_SERVICE_URL=http://payment-service:8089
NOTIFICATION_SERVICE_URL=http://notification-service:8090
WISHLIST_SERVICE_URL=http://wishlist-service:8095
SEARCH_SERVICE_URL=http://search-service:8091
REVIEW_SERVICE_URL=http://review-service:8092
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8093
ANALYTICS_SERVICE_URL=http://analytics-service:8094
